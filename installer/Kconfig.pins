  config PIN_ENCODER
    string
    prompt "Encoder pin" if MMU_HAS_ENCODER


  config PIN_NEOPIXEL
    string
    prompt "Neopixel pin" if MMU_HAS_LEDS


  config PIN_SHARED_EXIT_SENSOR
    string "MMU Shared exit sensor pin"


  config PIN_SYNC_FEEDBACK_TENSION
    string "Sync feedback tension pin"


  config PIN_SYNC_FEEDBACK_COMPRESSION
    string "Sync feedback compression pin"


  config PIN_SYNC_FEEDBACK_ANALOG
    string "Sync feedback proportional (analog) pin"


  config PIN_GANTRY_SERVO
    string "Gantry servo pin"

