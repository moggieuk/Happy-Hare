    config PIN_EXIT_SENSOR_1
      string
      prompt "Exit sensor 1 pin" if PARAM_NUM_GATES > 1
    config PIN_EXIT_SENSOR_2
      string
      prompt "Exit sensor 2 pin" if PARAM_NUM_GATES > 2
    config PIN_EXIT_SENSOR_3
      string
      prompt "Exit sensor 3 pin" if PARAM_NUM_GATES > 3
    config PIN_EXIT_SENSOR_4
      string
      prompt "Exit sensor 4 pin" if PARAM_NUM_GATES > 4
    config PIN_EXIT_SENSOR_5
      string
      prompt "Exit sensor 5 pin" if PARAM_NUM_GATES > 5
    config PIN_EXIT_SENSOR_6
      string
      prompt "Exit sensor 6 pin" if PARAM_NUM_GATES > 6
    config PIN_EXIT_SENSOR_7
      string
      prompt "Exit sensor 7 pin" if PARAM_NUM_GATES > 7
    config PIN_EXIT_SENSOR_8
      string
      prompt "Exit sensor 8 pin" if PARAM_NUM_GATES > 8
    config PIN_EXIT_SENSOR_9
      string
