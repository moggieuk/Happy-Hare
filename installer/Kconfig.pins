# This defines the symbol types, pins menu layout and changes to defaults.
# The defaults are set in the Kconfig.board_type under the boards directory.
#
# Responsible for defining all "PIN_*" parameters
# Note types must always be defined, the prompts are based on MMU capabilities
#
# Assumed that max gates:
#   for type-A boards is 12 (although currently max is 8)
#   for type-B boards is 5 (Chameleon X5)

menu "Pins"

  config HAS_ESPOOLER_ENABLE_PIN
    def_bool n

  menu "Gear pins"
    config PIN_GEAR_UART
      string "Gear UART pin"
    config PIN_GEAR_STEP
      string "Gear step pin"
    config PIN_GEAR_DIR
      string "Gear dir pin"
    config PIN_GEAR_ENABLE
      string "Gear enable pin"
    config PIN_GEAR_DIAG
      string "Gear diag pin"

    config PIN_GEAR_UART_1
      string
      prompt "Gear 1 UART pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 1
    config PIN_GEAR_STEP_1
      string
      prompt "Gear 1 step pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 1
    config PIN_GEAR_DIR_1
      string
      prompt "Gear 1 dir pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 1
    config PIN_GEAR_ENABLE_1
      string
      prompt "Gear 1 enable pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 1
    config PIN_GEAR_DIAG_1
      string
      prompt "Gear 1 diag pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 1

    config PIN_GEAR_UART_2
      string
      prompt "Gear 2 UART pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 2
    config PIN_GEAR_STEP_2
      string
      prompt "Gear 2 step pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 2
    config PIN_GEAR_DIR_2
      string
      prompt "Gear 2 dir pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 2
    config PIN_GEAR_ENABLE_2
      string
      prompt "Gear 2 enable pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 2
    config PIN_GEAR_DIAG_2
      string
      prompt "Gear 2 diag pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 2

    config PIN_GEAR_UART_3
      string
      prompt "Gear 3 UART pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 3
    config PIN_GEAR_STEP_3
      string
      prompt "Gear 3 step pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 3
    config PIN_GEAR_DIR_3
      string
      prompt "Gear 3 dir pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 3
    config PIN_GEAR_ENABLE_3
      string
      prompt "Gear 3 enable pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 3
    config PIN_GEAR_DIAG_3
      string
      prompt "Gear 3 diag pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 3

    config PIN_GEAR_UART_4
      string
      prompt "Gear 4 UART pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 4
    config PIN_GEAR_STEP_4
      string
      prompt "Gear 4 step pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 4
    config PIN_GEAR_DIR_4
      string
      prompt "Gear 4 dir pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 4
    config PIN_GEAR_ENABLE_4
      string
      prompt "Gear 4 enable pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 4
    config PIN_GEAR_DIAG_4
      string
      prompt "Gear 4 diag pin" if VIRTUAL_SELECTOR && PARAM_NUM_GATES > 4
  endmenu

  menu "Selector pins"
    config PIN_SELECTOR_UART
      string
      prompt "Selector UART pin" if LINEAR_SELECTOR || ROTARY_SELECTOR || INDEXED_SELECTOR
    config PIN_SELECTOR_STEP
      string
      prompt "Selector step pin" if LINEAR_SELECTOR || ROTARY_SELECTOR || INDEXED_SELECTOR
    config PIN_SELECTOR_DIR
      string
      prompt "Selector dir pin" if LINEAR_SELECTOR || ROTARY_SELECTOR || INDEXED_SELECTOR
    config PIN_SELECTOR_ENABLE
      string
      prompt "Selector enable pin" if LINEAR_SELECTOR || ROTARY_SELECTOR || INDEXED_SELECTOR
    config PIN_SELECTOR_DIAG
      string
      prompt "Selector diag pin" if LINEAR_SELECTOR || ROTARY_SELECTOR || INDEXED_SELECTOR
    config PIN_SELECTOR_ENDSTOP
      string
      prompt "Selector endstop pin" if LINEAR_SELECTOR || ROTARY_SELECTOR || INDEXED_SELECTOR
    config PIN_SELECTOR_SERVO
      string
      prompt "Servo pin" if LINEAR_SELECTOR || ROTARY_SELECTOR || INDEXED_SELECTOR
  endmenu

  menu "Mmu entry sensor pins"
