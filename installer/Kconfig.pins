  menu "eSpooler pins"
    config PIN_ESPOOLER_EN_0
      string
      prompt "eSpooler enable 0 pin" if MMU_HAS_ESPOOLER && PARAM_NUM_GATES > 0 && HAS_ESPOOLER_ENABLE_PIN
    config PIN_ESPOOLER_RWD_0
      string
      prompt "eSpooler rewind 0 pin" if MMU_HAS_ESPOOLER && PARAM_NUM_GATES > 0
    config PIN_ESPOOLER_FWD_0
      string
      prompt "eSpooler forward 0 pin" if MMU_HAS_ESPOOLER && PARAM_NUM_GATES > 0
    config PIN_ESPOOLER_TRIG_0
