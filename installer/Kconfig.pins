# -------------------------------------
# Shared Exit sensor
# -------------------------------------

  config PIN_SHARED_EXIT_SENSOR
    string
    prompt "Shared exit sensor pin" if MMU_HAS_SENSOR_SHARED_EXIT


# -------------------------------------
# Misc pins
# -------------------------------------

  config PIN_TOOLHEAD_SENSOR
    string
    prompt "Toolhead sensor pin   " if MMU_HAS_SENSOR_TOOLHEAD


  config PIN_EXTRUDER_SENSOR
    string
    prompt "Extruder sensor pin   " if MMU_HAS_SENSOR_EXTRUDER


  config PIN_ENCODER
    string
    prompt "Encoder pin           " if MMU_HAS_ENCODER


  config PIN_NEOPIXEL
    string
    prompt "Neopixel pin          " if MMU_HAS_LEDS


  config PIN_GANTRY_SERVO
    string "Gantry servo pin      "
    help
      Optional. Used to deploy fold-down "bumper" for tip cutting
      when using a toolhead mounted filament cutting blade


# -------------------------------------
# Addon pins (TODO: not yet integrated)
# -------------------------------------

  menu "Addons"
    depends on ADDON_EREC_CUTTER || ADDON_BLOBIFIER

    config PIN_EREC_CUTTER_SERVO
      string "EREC Cutter servo pin "  if ADDON_EREC_CUTTER

    config PIN_BLOBIFIER_SERVO
      string "Blobifer servo pin    "     if ADDON_BLOBIFIER

    config PIN_BLOBIFIER_BUCKET_SWITCH
      string "Blobifer bucket switch" if ADDON_BLOBIFIER

  endmenu

endmenu
