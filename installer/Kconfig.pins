# This defines the symbol types, pins menu layout and changes to defaults.
# The defaults are set in the Kconfig.board_type under the boards directory.
#
# Responsible for defining all "PIN_*" parameters
# Note types must always be defined, the prompts are based on MMU capabilities
#
# Assumed that max gates:
#   for type-A boards is 12 (although currently max is 8)
#   for type-B boards is 5 (Chameleon X5)

menu "Pins / TMC"

# -------------------------------------
# Gear TMC chip
# -------------------------------------

  choice CHOICE_GEAR_TMC
    prompt "Gear TMC chip"
    default CHOICE_GEAR_TMC_2209
    help
      Select correct TMC chip type for gear stepper.
      Can be changed by editing .cfg files directly.

    config CHOICE_GEAR_TMC_2209
      bool "TMC2209"
    config CHOICE_GEAR_TMC_2130
      bool "TMC2130"
    config CHOICE_GEAR_TMC_2208
      bool "TMC2208"
    config CHOICE_GEAR_TMC_2660
      bool "TMC2660"
    config CHOICE_GEAR_TMC_5160
      bool "TMC5160"
    config CHOICE_GEAR_TMC_2240
      bool "TMC2240"
  endchoice

  config PARAM_GEAR_TMC
      string
      default "tmc2209" if CHOICE_GEAR_TMC_2209
      default "tmc2130" if CHOICE_GEAR_TMC_2130
      default "tmc2208" if CHOICE_GEAR_TMC_2208
      default "tmc2660" if CHOICE_GEAR_TMC_2660
      default "tmc5160" if CHOICE_GEAR_TMC_5160
      default "tmc2240" if CHOICE_GEAR_TMC_2240

# -------------------------------------
# Gear stepper
# -------------------------------------

  menu "Gear pins"
    config PIN_GEAR_UART
      string "Gear UART pin    "
    config PIN_GEAR_STEP
      string "Gear step pin    "
    config PIN_GEAR_DIR
      string "Gear dir pin     "
    config PIN_GEAR_ENABLE
      string "Gear enable pin  "
    config PIN_GEAR_DIAG
      string "Gear diag pin    "

  # Additional gears for type-b/c MMU's

    config PIN_GEAR_UART_1
      string
    config PIN_GEAR_STEP_1
      string
    config PIN_GEAR_DIR_1
      string
    config PIN_GEAR_ENABLE_1
      string
    config PIN_GEAR_DIAG_1
      string

    config PIN_GEAR_UART_2
      string
    config PIN_GEAR_STEP_2
      string
    config PIN_GEAR_DIR_2
      string
    config PIN_GEAR_ENABLE_2
      string
    config PIN_GEAR_DIAG_2
      string

    config PIN_GEAR_UART_3
      string
    config PIN_GEAR_STEP_3
      string
    config PIN_GEAR_DIR_3
      string
    config PIN_GEAR_ENABLE_3
      string
    config PIN_GEAR_DIAG_3
      string

    config PIN_GEAR_UART_4
      string
    config PIN_GEAR_STEP_4
      string
    config PIN_GEAR_DIR_4
      string
    config PIN_GEAR_ENABLE_4
      string
    config PIN_GEAR_DIAG_4
      string

    if MULTIGEAR

      if PARAM_NUM_GATES > 1
        config PIN_GEAR_UART_1
          prompt "Gear 1 UART pin  "
        config PIN_GEAR_STEP_1
          prompt "Gear 1 step pin  "
        config PIN_GEAR_DIR_1
          prompt "Gear 1 dir pin   "
        config PIN_GEAR_ENABLE_1
          prompt "Gear 1 enable pin"
        config PIN_GEAR_DIAG_1
          prompt "Gear 1 diag pin  "
      endif

      if PARAM_NUM_GATES > 2
        config PIN_GEAR_UART_2
          prompt "Gear 2 UART pin  "
        config PIN_GEAR_STEP_2
          prompt "Gear 2 step pin  "
        config PIN_GEAR_DIR_2
          prompt "Gear 2 dir pin   "
        config PIN_GEAR_ENABLE_2
          prompt "Gear 2 enable pin"
        config PIN_GEAR_DIAG_2
          prompt "Gear 2 diag pin  "
      endif

      if PARAM_NUM_GATES > 3
        config PIN_GEAR_UART_3
          prompt "Gear 3 UART pin  "
        config PIN_GEAR_STEP_3
          prompt "Gear 3 step pin  "
        config PIN_GEAR_DIR_3
          prompt "Gear 3 dir pin   "
        config PIN_GEAR_ENABLE_3
          prompt "Gear 3 enable pin"
        config PIN_GEAR_DIAG_3
          prompt "Gear 3 diag pin  "
      endif

      if PARAM_NUM_GATES > 4
        config PIN_GEAR_UART_4
          prompt "Gear 4 UART pin  "
        config PIN_GEAR_STEP_4
          prompt "Gear 4 step pin  "
        config PIN_GEAR_DIR_4
          prompt "Gear 4 dir pin   "
        config PIN_GEAR_ENABLE_4
          prompt "Gear 4 enable pin"
        config PIN_GEAR_DIAG_4
          prompt "Gear 4 diag pin  "
      endif

    endif

  endmenu


# -------------------------------------
# Selector stepper and servo
# -------------------------------------

  config PIN_SELECTOR_UART
    string
  config PIN_SELECTOR_STEP
    string
  config PIN_SELECTOR_DIR
    string
  config PIN_SELECTOR_ENABLE
    string
  config PIN_SELECTOR_DIAG
    string
  config PIN_SELECTOR_ENDSTOP
    string
  config PIN_SELECTOR_SERVO
    string


# -------------------------------------
# Selector TMC chip
# -------------------------------------

  choice CHOICE_SELECTOR_TMC
    prompt "Selector TMC chip"
    default CHOICE_SELECTOR_TMC_2209
    depends on MMU_HAS_SELECTOR_STEPPER
    help
      Select correct TMC chip type for gear stepper.
      Can be changed by editing .cfg files directly.

    config CHOICE_SELECTOR_TMC_2209
      bool "TMC2209"
    config CHOICE_SELECTOR_TMC_2130
      bool "TMC2130"
    config CHOICE_SELECTOR_TMC_2208
      bool "TMC2208"
    config CHOICE_SELECTOR_TMC_2660
      bool "TMC2660"
    config CHOICE_SELECTOR_TMC_5160
      bool "TMC5160"
    config CHOICE_SELECTOR_TMC_2240
      bool "TMC2240"
  endchoice

  config PARAM_SELECTOR_TMC
      string
      default "tmc2209" if CHOICE_SELECTOR_TMC_2209
      default "tmc2130" if CHOICE_SELECTOR_TMC_2130
      default "tmc2208" if CHOICE_SELECTOR_TMC_2208
      default "tmc2660" if CHOICE_SELECTOR_TMC_2660
      default "tmc5160" if CHOICE_SELECTOR_TMC_5160
      default "tmc2240" if CHOICE_SELECTOR_TMC_2240

  menu "Selector pins"
    depends on MMU_HAS_SELECTOR_STEPPER || MMU_HAS_SELECTOR_SERVO

    if MMU_HAS_SELECTOR_STEPPER
      config PIN_SELECTOR_UART
        prompt "Selector UART pin   "
      config PIN_SELECTOR_STEP
        prompt "Selector step pin   "
      config PIN_SELECTOR_DIR
        prompt "Selector dir pin    "
      config PIN_SELECTOR_ENABLE
        prompt "Selector enable pin "
      config PIN_SELECTOR_DIAG
        prompt "Selector diag pin   "
      config PIN_SELECTOR_ENDSTOP
        prompt "Selector endstop pin"
    endif

    config PIN_SELECTOR_SERVO
      prompt "Servo pin           " if MMU_HAS_SELECTOR_SERVO
  endmenu


# -------------------------------------
# eSpooler
# -------------------------------------

  config HAS_ESPOOLER_ENABLE_PIN
    def_bool n

  config PIN_ESPOOLER_EN_0
    string
  config PIN_ESPOOLER_RWD_0
    string
  config PIN_ESPOOLER_FWD_0
    string
  config PIN_ESPOOLER_TRIG_0
    string

  config PIN_ESPOOLER_EN_1
    string
  config PIN_ESPOOLER_RWD_1
    string
  config PIN_ESPOOLER_FWD_1
    string
  config PIN_ESPOOLER_TRIG_1
    string

  config PIN_ESPOOLER_EN_2
    string
  config PIN_ESPOOLER_RWD_2
    string
  config PIN_ESPOOLER_FWD_2
    string
  config PIN_ESPOOLER_TRIG_2
    string

  config PIN_ESPOOLER_EN_3
    string
  config PIN_ESPOOLER_RWD_3
    string
  config PIN_ESPOOLER_FWD_3
    string
  config PIN_ESPOOLER_TRIG_3
    string

  config PIN_ESPOOLER_EN_4
    string
  config PIN_ESPOOLER_RWD_4
    string
  config PIN_ESPOOLER_FWD_4
    string
  config PIN_ESPOOLER_TRIG_4
    string

  menu "eSpooler pins"
    depends on MMU_HAS_ESPOOLER

    config PIN_ESPOOLER_EN_0
      prompt "eSpooler enable 0 pin " if PARAM_NUM_GATES > 0 && HAS_ESPOOLER_ENABLE_PIN
    config PIN_ESPOOLER_RWD_0
      prompt "eSpooler rewind 0 pin " if PARAM_NUM_GATES > 0
    config PIN_ESPOOLER_FWD_0
      prompt "eSpooler forward 0 pin" if PARAM_NUM_GATES > 0
    config PIN_ESPOOLER_TRIG_0
      prompt "eSpooler trigger 0 pin" if PARAM_NUM_GATES > 0

    config PIN_ESPOOLER_EN_1
      prompt "eSpooler enable 1 pin " if PARAM_NUM_GATES > 1 && HAS_ESPOOLER_ENABLE_PIN
    config PIN_ESPOOLER_RWD_1
      prompt "eSpooler rewind 1 pin " if PARAM_NUM_GATES > 1
    config PIN_ESPOOLER_FWD_1
      prompt "eSpooler forward 1 pin" if PARAM_NUM_GATES > 1
    config PIN_ESPOOLER_TRIG_1
      prompt "eSpooler trigger 1 pin" if PARAM_NUM_GATES > 1

    config PIN_ESPOOLER_EN_2
      prompt "eSpooler enable 2 pin " if PARAM_NUM_GATES > 2 && HAS_ESPOOLER_ENABLE_PIN
    config PIN_ESPOOLER_RWD_2
      prompt "eSpooler rewind 2 pin " if PARAM_NUM_GATES > 2
    config PIN_ESPOOLER_FWD_2
      prompt "eSpooler forward 2 pin" if PARAM_NUM_GATES > 2
    config PIN_ESPOOLER_TRIG_2
      prompt "eSpooler trigger 2 pin" if PARAM_NUM_GATES > 2

    config PIN_ESPOOLER_EN_3
      prompt "eSpooler enable 3 pin " if PARAM_NUM_GATES > 3 && HAS_ESPOOLER_ENABLE_PIN
    config PIN_ESPOOLER_RWD_3
      prompt "eSpooler rewind 3 pin " if PARAM_NUM_GATES > 3
    config PIN_ESPOOLER_FWD_3
      prompt "eSpooler forward 3 pin" if PARAM_NUM_GATES > 3
    config PIN_ESPOOLER_TRIG_3
      prompt "eSpooler trigger 3 pin" if PARAM_NUM_GATES > 3

    config PIN_ESPOOLER_EN_4
      prompt "eSpooler enable 4 pin " if PARAM_NUM_GATES > 4 && HAS_ESPOOLER_ENABLE_PIN
    config PIN_ESPOOLER_RWD_4
      prompt "eSpooler rewind 4 pin " if PARAM_NUM_GATES > 4
    config PIN_ESPOOLER_FWD_4
      prompt "eSpooler forward 4 pin" if PARAM_NUM_GATES > 4
    config PIN_ESPOOLER_TRIG_4
      prompt "eSpooler trigger 4 pin" if PARAM_NUM_GATES > 4
  endmenu


