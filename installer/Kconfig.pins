  config PIN_EJECT_BUTTON_11
    string

  menu "Mmu eject buttons"
    depends on MMU_HAS_EJECT_BUTTONS

    config PIN_EJECT_BUTTON_0
      prompt "Eject button 0 pin "  if PARAM_NUM_GATES > 0
    config PIN_EJECT_BUTTON_1
      prompt "Eject button 1 pin "  if PARAM_NUM_GATES > 1
    config PIN_EJECT_BUTTON_2
      prompt "Eject button 2 pin "  if PARAM_NUM_GATES > 2
    config PIN_EJECT_BUTTON_3
      prompt "Eject button 3 pin "  if PARAM_NUM_GATES > 3
    config PIN_EJECT_BUTTON_4
      prompt "Eject button 4 pin "  if PARAM_NUM_GATES > 4
    config PIN_EJECT_BUTTON_5
      prompt "Eject button 5 pin "  if PARAM_NUM_GATES > 5
    config PIN_EJECT_BUTTON_6
      prompt "Eject button 6 pin "  if PARAM_NUM_GATES > 6
    config PIN_EJECT_BUTTON_7
      prompt "Eject button 7 pin "  if PARAM_NUM_GATES > 7
    config PIN_EJECT_BUTTON_8
      prompt "Eject button 8 pin "  if PARAM_NUM_GATES > 8
    config PIN_EJECT_BUTTON_9
      prompt "Eject button 9 pin "  if PARAM_NUM_GATES > 9
    config PIN_EJECT_BUTTON_10
      prompt "Eject button 10 pin" if PARAM_NUM_GATES > 10
    config PIN_EJECT_BUTTON_11
      prompt "Eject button 11 pin" if PARAM_NUM_GATES > 11
  endmenu


# -------------------------------------
# Sync-Feedback Buffer
# -------------------------------------

  config PIN_SYNC_FEEDBACK_TENSION
    string
  config PIN_SYNC_FEEDBACK_COMPRESSION
    string
  config PIN_SYNC_FEEDBACK_ANALOG
    string

  menu "Sync-feedback Buffer"
    depends on MMU_HAS_SYNC_FEEDBACK_BUFFER

    config PIN_SYNC_FEEDBACK_TENSION
      prompt "Sync feedback tension pin    " if MMU_HAS_SENSOR_SYNC_FEEDBACK_TENSION
    config PIN_SYNC_FEEDBACK_COMPRESSION
      prompt "Sync feedback compression pin" if MMU_HAS_SENSOR_SYNC_FEEDBACK_COMPRESSION
    config PIN_SYNC_FEEDBACK_ANALOG
      prompt "Proportional (analog) pin    " if MMU_HAS_SENSOR_SYNC_FEEDBACK_PROPORTIONAL
  endmenu



