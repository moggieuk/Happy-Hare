# Force a logical order from mmu to extruder

menu "Filament sensors"
  help
    Specify any additional filament sensors you have incorporated here.
    This also allows for the installation of TMC stallguard based filament
    detection and homing option.

  rsource "Kconfig.entry"
  rsource "Kconfig.exit"
  rsource "Kconfig.shared_exit"
  rsource "Kconfig.gear_touch"
  if !MULTI_UNIT
    rsource "Kconfig.extruder"
    rsource "Kconfig.toolhead"
  endif
endmenu
