# Raw direct access to suggested parameters
# Generally grouped by sections of the .cfg files
# (Once user edits values here they are sticky and
# will override defaults)

menu "Raw Settings"
  help
    Raw Settings
    Allows override of designer defaults. Change these settings if you know
    what you are doing (or have MMU customizations). You can always change later
    by re-running "./install.sh -i" to run this editor (recommended) or by
    editing the generated klipper config files directly

  if !MULTI_UNIT_ENTRY_POINT
    source "Kconfig.extruder"
    source "Kconfig.num_gates"
  endif

  source "Kconfig.speeds"

  if !MULTI_UNIT_ENTRY_POINT
    source "Kconfig.gear_stepper"
    source "Kconfig.selector_stepper"
    source "Kconfig.selector_servo"
    source "sensors/Kconfig"
    source "Kconfig.endstops"
    source "Kconfig.gates"
    source "Kconfig.sync_control"
    source "Kconfig.flowguard"
    source "Kconfig.calibration"
    source "Kconfig.leds"
    source "Kconfig.encoder"
    source "Kconfig.heater"
    source "Kconfig.environment_sensor"
    source "Kconfig.sync_feedback_buffer"
  endif
endmenu
